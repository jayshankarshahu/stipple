{
    "manifest_version": 3,
    "name": "Stipple",
    "description": "A Notion-inspired dark mode note-taking extension with markdown, tags, and timeline view.",
    "version": "1.1.0",
    "action": {
        "default_popup": "index.html",
        "default_title": "Stipple"
    },
    "permissions": [
        "storage"
    ],
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    }
}